#
# Debian 12 + ROCm 7.2 + Python 3.11 Base Image
# This base image is used by all Triton build stages for onnxruntime/python backend with ROCm enabled on Debian OS to avoid redundant installations
#

FROM debian:12

# Prevent apt-get from prompting for input
ENV DEBIAN_FRONTEND=noninteractive

# Allow pip to install packages system-wide (needed for Debian 12+)
ENV PIP_BREAK_SYSTEM_PACKAGES=1

WORKDIR /workspace

# Install basic dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        locales \
        ca-certificates \
        wget \
        gnupg2 \
        curl \
        software-properties-common \
        build-essential \
        git \
        pkg-config && \
    rm -rf /var/lib/apt/lists/*

# Need this for debian
RUN sed -i 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/g' /etc/locale.gen
RUN echo 'LANG=en_US.UTF-8' > /etc/default/locale
RUN locale-gen en_US.UTF-8
RUN update-locale LANG=en_US.UTF-8

ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

# Install Python from Debian 12 (bookworm) - default is 3.11
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-dev \
        python3-venv && \
    ln -sf /usr/bin/python3 /usr/bin/python && \
    curl -sS https://bootstrap.pypa.io/get-pip.py | python3 && \
    python3 -m pip install --upgrade pip setuptools==69.5.1 wheel && \
    python3 --version && \
    rm -rf /var/lib/apt/lists/*

# Install ROCm 7.2 (runtime + development packages) on Debian 12
RUN wget https://repo.radeon.com/amdgpu-install/7.2/ubuntu/jammy/amdgpu-install_7.2.70200-1_all.deb && \
    apt-get update && \
    apt-get install -y --no-install-recommends ./amdgpu-install_7.2.70200-1_all.deb && \
    rm amdgpu-install_7.2.70200-1_all.deb && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        rocm-dev \
        rocm-libs \
        hip-base \
        hip-dev \
        rocm-device-libs \
        rocblas \
        rocblas-dev \
        hipblas \
        hipblas-dev \
        miopen-hip \
        miopen-hip-dev \
        rocrand \
        rocrand-dev \
        rccl \
        rccl-dev && \
    rm -rf /var/lib/apt/lists/*

# Install libevent (needed by Triton for HTTP/gRPC endpoints)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libevent-2.1-7 \
        libevent-core-2.1-7 \
        libevent-pthreads-2.1-7 \
        libevent-dev && \
    rm -rf /var/lib/apt/lists/*

# Install common runtime dependencies used by Triton
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libb64-0d \
        libcurl4-openssl-dev \
        libre2-9 \
        libre2-dev \
        libnuma-dev \
        libnuma1 \
        libgoogle-perftools-dev \
        libjemalloc-dev && \
    rm -rf /var/lib/apt/lists/*


# Install cmake
RUN apt update -q=2 && apt install -y wget && \
    wget -q https://github.com/Kitware/CMake/releases/download/v3.28.3/cmake-3.28.3-linux-x86_64.tar.gz && \
    tar -zxf cmake-3.28.3-linux-x86_64.tar.gz -C /opt && \
    rm cmake-3.28.3-linux-x86_64.tar.gz && \
    ln -sf /opt/cmake-3.28.3-linux-x86_64/bin/cmake /usr/local/bin/cmake && \
    ln -sf /opt/cmake-3.28.3-linux-x86_64/bin/ctest /usr/local/bin/ctest && \
    ln -sf /opt/cmake-3.28.3-linux-x86_64/bin/cpack /usr/local/bin/cpack && \
    cmake --version 

# Set ROCm environment variables
ENV ROCM_PATH=/opt/rocm
ENV HIP_PATH=/opt/rocm
ENV PATH=/opt/rocm/bin:${PATH}
ENV LD_LIBRARY_PATH=/opt/rocm/lib:${LD_LIBRARY_PATH}


